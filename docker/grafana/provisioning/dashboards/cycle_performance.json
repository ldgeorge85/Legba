{
  "__inputs": [
    {
      "name": "DS_TIMESCALEDB",
      "label": "TimescaleDB",
      "description": "",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Cycle Duration by Type",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time_bucket('1h', time) AS time, dimension AS metric, AVG(value) AS value FROM metrics WHERE metric = 'cycle_duration_s' AND $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Success Rate",
      "type": "gauge",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT time, value FROM metrics WHERE metric = 'cycle_success' AND $__timeFilter(time) ORDER BY time DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Actions per Cycle",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "orientation": "vertical",
        "barWidth": 0.8,
        "groupWidth": 0.7
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time_bucket('1h', time) AS time, dimension AS metric, SUM(value) AS value FROM metrics WHERE metric = 'cycle_actions' AND $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["legba", "cycles"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Cycle Performance",
  "uid": "legba-cycle-performance",
  "version": 1
}
