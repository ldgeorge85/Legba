# Legba — Claude Instance Configuration
#
# Copy to .env.claude and fill in your API key:
#   cp .env.claude.example .env.claude

# --- LLM Provider ---
LLM_PROVIDER=anthropic
OPENAI_API_KEY=sk-ant-api03-YOUR-KEY-HERE
OPENAI_MODEL=claude-sonnet-4-20250514

# Claude tuning
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_MAX_TOKENS=16384
LLM_TIMEOUT=300
LLM_MAX_CONTEXT_TOKENS=200000

# --- Embeddings ---
# Anthropic has no embedding API. Point to your vLLM instance.
EMBEDDING_API_BASE=http://your-vllm-host:8000/v1
EMBEDDING_API_KEY=your-embedding-key
MEMORY_EMBEDDING_MODEL=embedding-inno1
MEMORY_VECTOR_DIMENSIONS=1024

# --- Agent tuning ---
AGENT_MAX_REASONING_STEPS=20
AGENT_MAX_CONTEXT_TOKENS=190000
