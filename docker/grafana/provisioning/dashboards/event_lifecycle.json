{
  "__inputs": [
    {
      "name": "DS_TIMESCALEDB",
      "label": "TimescaleDB",
      "description": "",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Event Lifecycle Distribution",
      "type": "barchart",
      "gridPos": { "h": 14, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "orientation": "vertical",
        "barWidth": 0.8,
        "groupWidth": 0.7
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time_bucket('1h', time) AS time, dimension AS metric, SUM(value) AS value FROM metrics WHERE metric = 'event_lifecycle_distribution' AND $__timeFilter(time) GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Events Created (24h)",
      "type": "stat",
      "gridPos": { "h": 14, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time, value FROM metrics WHERE metric = 'events_created_24h' AND $__timeFilter(time) ORDER BY time DESC LIMIT 1",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["legba", "events"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Event Lifecycle",
  "uid": "legba-event-lifecycle",
  "version": 1
}
