# Legba — Environment Configuration
# Copy to .env and fill in your values.

# --- LLM Provider ---
# For vLLM / OpenAI-compatible endpoints:
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=http://your-vllm-host:8000/v1
OPENAI_MODEL=your-model-name

# LLM Parameters
LLM_TEMPERATURE=1.0
LLM_TOP_P=1.0
LLM_MAX_TOKENS=16384

# --- Embeddings ---
# If using a separate embedding endpoint (e.g. when LLM provider has no embeddings):
# EMBEDDING_API_BASE=http://your-embedding-host:8000/v1
# EMBEDDING_API_KEY=your-embedding-key
MEMORY_EMBEDDING_MODEL=your-embedding-model
MEMORY_VECTOR_DIMENSIONS=1024

# --- Agent tuning ---
AGENT_MAX_REASONING_STEPS=30
AGENT_MAX_CONTEXT_TOKENS=120000
AGENT_SHELL_TIMEOUT=120
AGENT_HTTP_TIMEOUT=120
# AGENT_MEMORY_RETRIEVAL_LIMIT=20
# AGENT_FACTS_RETRIEVAL_LIMIT=20
# AGENT_BOOTSTRAP_THRESHOLD=5

# --- Supervisor tuning ---
SUPERVISOR_HEARTBEAT_TIMEOUT=600
# SUPERVISOR_MAX_FAILURES=5
# SUPERVISOR_CYCLE_SLEEP=2.0
